# Finance Genie Client local environment.
# Copy this file to .env.local for local development.
# Do not commit .env.local.

# SQL warehouse used by the Databricks SQL connector when running locally.
# In deployed Databricks Apps, this comes from app.yaml valueFrom: sql-warehouse.
DATABRICKS_WAREHOUSE_ID=<your-sql-warehouse-id>

# Unity Catalog namespace for the finance-genie tables.
CATALOG=graph-enriched-lakehouse
SCHEMA=graph-enriched-schema

# Optional Databricks CLI/SDK profile for local app auth and deploy scripts.
# Use this when your credentials live in ~/.databrickscfg.
# DATABRICKS_CONFIG_PROFILE=<your-databricks-profile>

# Optional deployment convenience. When true, scripts/deploy_app.sh grants the
# app service principal read access to CATALOG.SCHEMA.
# GRANT_APP_SP_SCHEMA_ACCESS=false

# Optional MCP schema page configuration. MCP_SCHEMA_CONNECTION_NAME should be a
# Unity Catalog HTTP connection that points at an MCP server.
# MCP_SCHEMA_CONNECTION_NAME=<uc-http-connection-name>
# MCP_SCHEMA_PATH=/
# MCP_SCHEMA_TOOL_NAME=get_full_schema

# Alternative local auth style:
# DATABRICKS_HOST=https://<workspace-host>
# DATABRICKS_TOKEN=<personal-access-token>

# Optional local Streamlit binding.
# HOST=127.0.0.1
# PORT=8501
