# Compatibility template.
# Prefer finance-genie/.env.sample copied to finance-genie/.env.
# fraud-analyst — copy to .env and fill in values.
#
#   cp .env.sample .env
#
# .env is gitignored. Never commit real values.
#
# Replace the placeholders below with values from your Databricks workspace.

# ── Databricks workspace ──────────────────────────────────────────────
# Profile from ~/.databrickscfg. Used by scripts/deploy.sh.
DATABRICKS_PROFILE=<your-databricks-profile>

# ── Databricks resources ──────────────────────────────────────────────
# SQL warehouse the FastAPI service uses to query gold tables.
# Find via: databricks warehouses list --profile $DATABRICKS_PROFILE
FRAUD_ANALYST_WAREHOUSE_ID=<sql-warehouse-id>

# Genie Space for the AFTER-GDS conversational experience.
# Find via: databricks api get /api/2.0/genie/spaces --profile $DATABRICKS_PROFILE
FRAUD_ANALYST_GENIE_SPACE_ID=<genie-space-id>

# Unity Catalog catalog + schema holding the gold tables. Names include
# hyphens; the backend quotes them with backticks at query time.
FRAUD_ANALYST_CATALOG=<catalog-name>
FRAUD_ANALYST_SCHEMA=<schema-name>

# ── Local dev only ────────────────────────────────────────────────────
# Required only when running `apx dev start` against a real workspace.
# When deployed to Databricks Apps these are injected automatically.
# DATABRICKS_HOST=https://<workspace-host>
# DATABRICKS_TOKEN=<databricks-token>
