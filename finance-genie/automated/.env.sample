# finance-genie — copy this file to automated/.env and fill in your values.
# Never commit .env (real values) to source control.
# All scripts in automated/ load from automated/.env via config.py / dotenv.

# ── Neo4j ─────────────────────────────────────────────────────────────
# Connection details for the Aura (or self-managed) Neo4j instance that
# hosts the graph projection and runs GDS algorithms. Consumed by the
# neo4j_ingest job and by setup_secrets.sh, which mirrors these values
# into the Databricks secret scope below.

# Bolt+routing URI for the Neo4j instance (Aura uses neo4j+s://).
NEO4J_URI='neo4j+s://<your-instance>.databases.neo4j.io'
# Database user with write access to the target database.
NEO4J_USERNAME='neo4j'
# Password for NEO4J_USERNAME.
NEO4J_PASSWORD='<your-neo4j-password>'

# ── Databricks ────────────────────────────────────────────────────────
# Workspace connection, compute target, and Unity Catalog locations used
# by the CLI submit wrappers, upload_and_create_tables.sh, and the
# validation scripts under validation/.

# Named profile in ~/.databrickscfg to authenticate against.
DATABRICKS_PROFILE=<your-databricks-profile>
# Compute target for submitted jobs: "cluster" or "serverless".
DATABRICKS_COMPUTE_MODE=cluster
# All-purpose cluster ID used when DATABRICKS_COMPUTE_MODE=cluster.
# Format: NNNN-NNNNNN-xxxxxxxx (validated by validation/validate_cluster.py).
DATABRICKS_CLUSTER_ID=<your-cluster-id>
# Workspace path where submit wrappers stage job code before running.
DATABRICKS_WORKSPACE_DIR=/Users/<you>@<domain>/graph-enriched-lakehouse/automated
# Unity Catalog Volume for CSV uploads, ground_truth.json, and result
# artifacts. Must match CATALOG/SCHEMA below.
DATABRICKS_VOLUME_PATH=/Volumes/<catalog>/<schema>/<volume>
# SQL warehouse used by upload_and_create_tables.sh to run schema DDL
# and INSERT OVERWRITE statements against the base tables.
DATABRICKS_WAREHOUSE_ID=<your-sql-warehouse-id>
# Unity Catalog catalog that owns the base + gold tables.
CATALOG=graph-enriched-lakehouse
# Schema within CATALOG for the finance-genie tables.
SCHEMA=graph-enriched-schema
# Databricks secret scope holding Neo4j credentials and Genie space IDs.
# Populated by setup_secrets.sh; read by neo4j_ingest at runtime.
NEO4J_SECRET_SCOPE=neo4j-graph-engineering

# ── Genie test runners ─────────────────────────────────────────────────
# Parameters for jobs/genie_run.py and its before/after submit wrappers,
# which query Genie Spaces with analyst-phrased questions and record
# SQL + rows to a result artifact.

# Genie Space configured with the 4 base tables only (pre-GDS baseline).
GENIE_SPACE_ID_BEFORE=<before-gds-genie-space-id>
# Genie Space configured with the 4 base tables plus the 2 gold tables
# produced by GDS enrichment.
GENIE_SPACE_ID_AFTER=<after-gds-genie-space-id>
# UC Volume path to ground_truth.json — expected answers the runner
# compares against. ring_community_map.json is read from the same dir.
GROUND_TRUTH_PATH=/Volumes/<catalog>/<schema>/<volume>/ground_truth.json
# UC Volume directory where JSON result artifacts are written.
RESULTS_VOLUME_DIR=/Volumes/<catalog>/<schema>/<volume>/genie_test_results
# How many times to retry a Genie question before giving up.
GENIE_TEST_RETRIES=2
# Per-question wall-clock timeout, in seconds.
GENIE_TEST_TIMEOUT_SECONDS=120

# ── Seed ──────────────────────────────────────────────────────────────
# Single RNG seed threaded through setup/generate_data.py so synthetic
# data is reproducible across runs.
SEED=42

# ── Scale ─────────────────────────────────────────────────────────────
# Dataset size knobs. Change these to shrink/enlarge the generated data.
# Not for signal tuning — see PRIMARY TUNING KNOBS below for that.

# Number of account nodes to generate.
NUM_ACCOUNTS=25000
# Number of merchant nodes to generate.
NUM_MERCHANTS=7500
# Number of account→merchant transaction edges.
NUM_TXN=250000
# Number of account→account P2P transfer edges.
NUM_P2P=300000
# Fraction of accounts flagged as fraud (ring members + smurfs).
FRAUD_RATE=0.04
# Number of distinct fraud rings to plant in the data.
N_RINGS=10
# Fraction of accounts designated as whales (high-volume legitimate).
WHALE_RATE=0.008

# ── PRIMARY TUNING KNOBS ──────────────────────────────────────────────
# Signal-strength parameters. Tier 5 validated values — pass
# verify_fraud_patterns.py 4/4 and GDS 4/4. See
# worklog/PARAMETER_CALIBRATION.md for the full calibration history.

# WITHIN_RING_PROB — fraction of P2P links that stay within a ring.
# Primary driver of density ratio (~3,400× at 0.35; 93% internal edge ratio).
WITHIN_RING_PROB=0.35

# WHALE_INBOUND — fraction of P2P links directed to whale accounts.
# Whale outbound is hardcoded equal to this value in setup/generate_data.py.
WHALE_INBOUND=0.14

# RING_ANCHOR_PREF — probability a fraud account visits an anchor merchant.
# Primary driver of Jaccard ratio and NodeSimilarity separation.
RING_ANCHOR_PREF=0.35

# Note: WHALE_OUTBOUND, WHALE_FIXED_OUTBOUND, WHALE_RECIPIENT_POOL_SIZE,
# RING_ANCHOR_CNT, CAPTAIN_COUNT, CAPTAIN_TRANSFER_PROB, and the six lognormal
# distribution parameters are now hardcoded in setup/generate_data.py. See
# worklog/SIMPLIFY.md for the reasoning. Edit the module to change them.
