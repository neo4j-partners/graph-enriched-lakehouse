# finance-genie — copy this file to automated/.env and fill in your values.
# Never commit .env (real values) to source control.
# All scripts in automated/ load from automated/.env.

# ── Neo4j ─────────────────────────────────────────────────────────────
NEO4J_URI='neo4j+s://<your-instance>.databases.neo4j.io'
NEO4J_USERNAME='neo4j'
NEO4J_PASSWORD='<your-neo4j-password>'

# ── Databricks ────────────────────────────────────────────────────────
DATABRICKS_PROFILE=azure-rk-knight
DATABRICKS_COMPUTE_MODE=cluster
DATABRICKS_CLUSTER_ID=<your-cluster-id>
DATABRICKS_WORKSPACE_DIR=/Users/<you>@<domain>/graph-enriched-lakehouse/automated
DATABRICKS_VOLUME_PATH=/Volumes/<catalog>/<schema>/<volume>
DATABRICKS_WAREHOUSE_ID=<your-sql-warehouse-id>
CATALOG=graph-enriched-lakehouse
SCHEMA=graph-enriched-schema
NEO4J_SECRET_SCOPE=neo4j-graph-engineering

# ── Genie test runners ─────────────────────────────────────────────────
# genie_test_before.py — Genie Space with 4 base tables (before GDS enrichment)
GENIE_SPACE_ID_BEFORE=<before-gds-genie-space-id>
# genie_test.py — Genie Space with 4 base tables + 2 gold tables (after GDS enrichment)
GENIE_SPACE_ID_AFTER=<after-gds-genie-space-id>
GROUND_TRUTH_PATH=/Volumes/<catalog>/<schema>/<volume>/ground_truth.json
RESULTS_VOLUME_DIR=/Volumes/<catalog>/<schema>/<volume>/genie_test_results
GENIE_TEST_RETRIES=2
GENIE_TEST_TIMEOUT_SECONDS=120

# ── Seed ──────────────────────────────────────────────────────────────
SEED=42

# ── Scale ─────────────────────────────────────────────────────────────
# Change these to adjust dataset size. Not for signal tuning.
NUM_ACCOUNTS=25000
NUM_MERCHANTS=7500
NUM_TXN=250000
NUM_P2P=300000
FRAUD_RATE=0.04
N_RINGS=10
WHALE_RATE=0.008

# ── PRIMARY TUNING KNOBS ──────────────────────────────────────────────
# Tier 5 validated values — pass verify_fraud_patterns.py 4/4 and GDS 4/4.
# See worklog/PARAMETER_CALIBRATION.md for the full calibration history.

# WITHIN_RING_PROB — fraction of P2P links that stay within a ring.
# Primary driver of density ratio (~3,400× at 0.35; 93% internal edge ratio).
WITHIN_RING_PROB=0.35

# WHALE_INBOUND — fraction of P2P links directed to whale accounts.
WHALE_INBOUND=0.14

# WHALE_OUTBOUND — fraction of P2P links originating from whale accounts.
# Set equal to WHALE_INBOUND so inbound and outbound volumes are symmetric.
WHALE_OUTBOUND=0.14

# WHALE_FIXED_OUTBOUND — controls whale outbound recipient selection.
# true: each whale sends to a fixed pool of recurring recipients (default).
# false: outbound goes to random accounts across the full population.
WHALE_FIXED_OUTBOUND=true

# WHALE_RECIPIENT_POOL_SIZE — size of each whale's fixed outbound recipient pool.
# Only used when WHALE_FIXED_OUTBOUND=true.
WHALE_RECIPIENT_POOL_SIZE=30

# RING_ANCHOR_PREF — probability a fraud account visits an anchor merchant.
# Primary driver of Jaccard ratio and NodeSimilarity separation.
RING_ANCHOR_PREF=0.35

# RING_ANCHOR_CNT — number of shared anchor merchants per ring.
RING_ANCHOR_CNT=4

# CAPTAIN_COUNT — number of captains designated per ring.
CAPTAIN_COUNT=5

CAPTAIN_TRANSFER_PROB=0.02

# ── Transaction amount distributions ─────────────────────────────────
# Tabular signal is already near-realistic. Change only to adjust
# tabular signal independently of graph signal.
FRAUD_LOGNORM_MU=4.1
FRAUD_LOGNORM_SIGMA=1.2
NORMAL_LOGNORM_MU=4.0
NORMAL_LOGNORM_SIGMA=1.2
P2P_LOGNORM_MU=5.0
P2P_LOGNORM_SIGMA=1.5
