# Compatibility template for simple-finance-agnet demo.
# Prefer finance-genie/.env.sample copied to finance-genie/.env.
# Copy this file to .env only for older project-local workflows.

# Databricks authentication and job staging.
DATABRICKS_PROFILE=<your-databricks-profile>
DATABRICKS_COMPUTE_MODE=serverless
DATABRICKS_CLUSTER_ID=
DATABRICKS_SERVERLESS_ENV_VERSION=3
DATABRICKS_WORKSPACE_DIR=/Users/<you>@<domain>/graph-enriched-lakehouse/multi-agent-demo

# Unity Catalog location for model registration.
CATALOG=graph-enriched-lakehouse
SCHEMA=graph-enriched-schema

# Existing external Neo4j MCP Unity Catalog connection. Create and validate it
# first with finance-genie/neo4j-mcp-demo/deploy.sh.
UC_CONNECTION_NAME=neo4j_agentcore_mcp

# Agent serving.
LLM_ENDPOINT_NAME=databricks-claude-sonnet-4-6
UC_MODEL_NAME=simple-finance-agnet
MODEL_SERVING_ENDPOINT_NAME=simple-finance-agnet

# Smoke-test prompt used by the endpoint validation job.
SMOKE_TEST_PROMPT=Use the Neo4j MCP read-only Cypher tool with exactly this query: RETURN 1 AS ok. Return the result and mention that the MCP tool call succeeded.
