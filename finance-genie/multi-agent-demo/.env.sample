# Finance Genie Neo4j GDS fraud specialist demo.
# Copy to .env and fill in workspace-specific values. Never commit .env.

# Databricks authentication and job staging.
DATABRICKS_PROFILE=<your-databricks-profile>
DATABRICKS_COMPUTE_MODE=cluster
DATABRICKS_CLUSTER_ID=<your-cluster-id>
DATABRICKS_SERVERLESS_ENV_VERSION=3
DATABRICKS_WORKSPACE_DIR=/Users/<you>@<domain>/graph-enriched-lakehouse/multi-agent-demo
# Optional but preferred for local UC connection provisioning. If omitted, the
# provisioning script falls back to DATABRICKS_CLUSTER_ID for SQL execution.
DATABRICKS_WAREHOUSE_ID=<your-sql-warehouse-id>

# Finance Genie Unity Catalog locations used for base-table readiness checks
# and UC model registration.
CATALOG=graph-enriched-lakehouse
SCHEMA=graph-enriched-schema

# External Neo4j MCP Unity Catalog connection.
# The deployed graph specialist receives only this connection name. The
# connection itself uses secrets stored in MCP_SECRET_SCOPE.
UC_CONNECTION_NAME=neo4j_agentcore_mcp
MCP_SECRET_SCOPE=mcp-neo4j-secrets
AGENTCORE_CREDENTIALS_PATH=.mcp-credentials.json

# Agent serving.
LLM_ENDPOINT_NAME=databricks-claude-sonnet-4-6
UC_MODEL_NAME=finance_neo4j_gds_fraud_specialist
MODEL_SERVING_ENDPOINT_NAME=finance-neo4j-gds-fraud-specialist

# Smoke-test prompt used by the endpoint validation job.
SMOKE_TEST_PROMPT=Find likely fraud-ring candidates from Neo4j GDS results. Return compact account IDs, graph evidence, and a recommended BEFORE Genie follow-up prompt for silver-table analysis.
