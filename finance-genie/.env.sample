# finance-genie shared environment.
# Copy this file to .env at the finance-genie repo root and fill in values.
# Never commit .env.

# ── Databricks workspace ──────────────────────────────────────────────
DATABRICKS_PROFILE=<your-databricks-profile>
DATABRICKS_CONFIG_PROFILE=<your-databricks-profile>
DATABRICKS_HOST=https://<workspace-host>
# DATABRICKS_TOKEN=<personal-access-token>

# Compute and workspace staging used by enrichment-pipeline/, MCP, and agents.
DATABRICKS_COMPUTE_MODE=cluster
DATABRICKS_CLUSTER_ID=<your-cluster-id>
DATABRICKS_SERVERLESS_ENV_VERSION=3
DATABRICKS_WORKSPACE_DIR=/Users/<you>@<domain>/graph-on-databricks/enrichment-pipeline
DATABRICKS_WAREHOUSE_ID=<your-sql-warehouse-id>

# Unity Catalog defaults.
CATALOG=graph-on-databricks
SCHEMA=graph-enriched-schema
DATABRICKS_CATALOG=graph-on-databricks
DATABRICKS_SCHEMA=graph-enriched-schema
DATABRICKS_VOLUME=graph-enriched-volume
DATABRICKS_VOLUME_PATH=/Volumes/graph-on-databricks/graph-enriched-schema/graph-enriched-volume

# ── Neo4j ─────────────────────────────────────────────────────────────
NEO4J_URI=neo4j+s://<your-instance>.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=<your-neo4j-password>
NEO4J_SECRET_SCOPE=neo4j-graph-engineering

# ── Genie ─────────────────────────────────────────────────────────────
GENIE_SPACE_ID_BEFORE=<before-gds-genie-space-id>
GENIE_SPACE_ID_AFTER=<after-gds-genie-space-id>
# Simple Finance Analyst generally uses the AFTER space.
GENIE_SPACE_ID=<after-gds-genie-space-id>
GROUND_TRUTH_PATH=/Volumes/<catalog>/<schema>/<volume>/ground_truth.json
RESULTS_VOLUME_DIR=/Volumes/<catalog>/<schema>/<volume>/genie_test_results
GENIE_TEST_RETRIES=2
GENIE_TEST_TIMEOUT_SECONDS=120

# ── simple-finance-analyst app ───────────────────────────────────────
USE_MOCK_BACKEND=true
DATABRICKS_APP_PORT=8000
SIMPLE_FINANCE_ANALYST_SECRET_SCOPE=simple-finance-analyst

# ── simple-finance-analyst MCP tooling ───────────────────────────────
MCP_SCHEMA_CONNECTION_NAME=neo4j_agentcore_mcp
MCP_SCHEMA_PATH=/
MCP_SCHEMA_TOOL_NAME=neo4j-mcp-server-target___get-schema
MCP_SCHEMA_TOOL_ARGUMENTS=properties
MCP_CYPHER_TOOL_NAME=neo4j-mcp-server-target___read-cypher
GRANT_APP_SP_SCHEMA_ACCESS=false
GRANT_APP_SP_MCP_CONNECTION_ACCESS=true
HOST=127.0.0.1
PORT=8501

# ── Neo4j MCP demo ───────────────────────────────────────────────────
AGENTCORE_CREDENTIALS_PATH=neo4j-mcp-demo/.mcp-credentials.json
MCP_SECRET_SCOPE=mcp-neo4j-secrets
UC_CONNECTION_NAME=neo4j_agentcore_mcp
UC_MODEL_NAME=neo4j_mcp_agent
LLM_ENDPOINT_NAME=databricks-claude-sonnet-4-6
MODEL_SERVING_ENDPOINT_NAME=neo4j-mcp-agent
SMOKE_TEST_PROMPT=What is the schema of the Neo4j database? Show node labels and relationship types.

# ── simple-finance-agent ─────────────────────────────────────────────
# Project-specific values avoid clobbering the neo4j-mcp-demo defaults above.
SIMPLE_FINANCE_AGENT_DATABRICKS_WORKSPACE_DIR=/Users/<you>@<domain>/graph-on-databricks/simple-finance-agent
SIMPLE_FINANCE_AGENT_UC_MODEL_NAME=simple-finance-agent
SIMPLE_FINANCE_AGENT_MODEL_SERVING_ENDPOINT_NAME=simple-finance-agent
SIMPLE_FINANCE_AGENT_SMOKE_TEST_PROMPT=Use the Neo4j MCP read-only Cypher tool with exactly this query: RETURN 1 AS ok. Return the result and mention that the MCP tool call succeeded.

# ── graph-fraud-analyst ──────────────────────────────────────────────
GRAPH_FRAUD_ANALYST_WAREHOUSE_ID=<sql-warehouse-id>
GRAPH_FRAUD_ANALYST_GENIE_SPACE_ID=<after-gds-genie-space-id>
GRAPH_FRAUD_ANALYST_CATALOG=graph-on-databricks
GRAPH_FRAUD_ANALYST_SCHEMA=graph-enriched-schema

# ── Synthetic data generation ────────────────────────────────────────
SEED=42
NUM_ACCOUNTS=25000
NUM_MERCHANTS=7500
NUM_TXN=250000
NUM_P2P=300000
FRAUD_RATE=0.04
N_RINGS=10
WHALE_RATE=0.008
WITHIN_RING_PROB=0.35
WHALE_INBOUND=0.14
RING_ANCHOR_PREF=0.35
