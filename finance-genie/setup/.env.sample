# finance-genie generator configuration
# Copy this file to .env (same directory) and edit to override any value.
# Shell environment variables take precedence over values set here.
#
# See config.py for descriptions of every parameter.
# See worklog/strengthen_plan.md for the per-phase tuning schedule.

# ── Seed ──────────────────────────────────────────────────────────────
SEED=42

# ── Scale ─────────────────────────────────────────────────────────────
# Change these to adjust dataset size. Not for signal tuning.
NUM_ACCOUNTS=25000
NUM_MERCHANTS=2500
NUM_TXN=250000
NUM_P2P=40000
FRAUD_RATE=0.04
N_RINGS=10
WHALE_RATE=0.008

# ── PRIMARY TUNING KNOBS ──────────────────────────────────────────────
# These four parameters control graph signal strength. Adjust these
# to move across phases. See worklog/strengthen_plan.md for targets.

# WITHIN_RING_PROB — fraction of P2P links that stay within a ring.
# Primary driver of density ratio. Current 0.30 → ~2726x ratio.
# Phase 2: 0.12  Phase 3: 0.035  Phase 4: 0.012  Phase 5: 0.004
WITHIN_RING_PROB=0.30

# WHALE_INBOUND — fraction of P2P links directed to whale accounts.
# Controls how strongly raw inbound count misdirects Genie.
# Hold constant unless Genie starts naming ring members in centrality query.
WHALE_INBOUND=0.20

# WHALE_OUTBOUND — fraction of P2P links originating from whale accounts.
# Set equal to WHALE_INBOUND so inbound and outbound volumes are symmetric,
# making whales resemble payment aggregators rather than pure collection accounts.
WHALE_OUTBOUND=0.20

# WHALE_FIXED_OUTBOUND — controls whale outbound recipient selection.
# true:  each whale sends to a fixed pool of recurring recipients (default).
#        This produces the consistent-counterparty pattern of a real aggregator.
# false: outbound goes to random accounts across the full population.
WHALE_FIXED_OUTBOUND=true

# WHALE_RECIPIENT_POOL_SIZE — size of each whale's fixed outbound recipient pool.
# Only used when WHALE_FIXED_OUTBOUND=true.  Recipients are sampled from plain
# normal accounts (not whales, not ring members) so they stay low-degree,
# preserving the sender-peripherality property that PageRank relies on.
WHALE_RECIPIENT_POOL_SIZE=30

# RING_ANCHOR_PREF — probability a fraud account visits an anchor merchant.
# Primary driver of Jaccard ratio. Current 0.18 → ~14.78x ratio.
# Phase 2: 0.09  Phase 3: 0.045  Phase 4: 0.022  Phase 5: 0.008
RING_ANCHOR_PREF=0.18

# RING_ANCHOR_CNT — number of shared anchor merchants per ring.
# Sets the Jaccard ceiling. Reduce alongside RING_ANCHOR_PREF.
# Phase 2: 4  Phase 3: 3  Phase 4: 2  Phase 5: 2
RING_ANCHOR_CNT=5

# ── Transaction amount distributions ─────────────────────────────────
# Tabular signal is already near-realistic. Change only to adjust
# tabular signal independently of graph signal.
FRAUD_LOGNORM_MU=4.1
FRAUD_LOGNORM_SIGMA=1.2
NORMAL_LOGNORM_MU=4.0
NORMAL_LOGNORM_SIGMA=1.2
P2P_LOGNORM_MU=5.0
P2P_LOGNORM_SIGMA=1.5
