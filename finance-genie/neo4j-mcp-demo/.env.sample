# Compatibility template.
# Prefer finance-genie/.env.sample copied to finance-genie/.env.
#
# Databricks authentication
# Leave DATABRICKS_PROFILE empty to use standard SDK env auth.
DATABRICKS_PROFILE=

# Job runner settings
DATABRICKS_COMPUTE_MODE=cluster
DATABRICKS_CLUSTER_ID=
DATABRICKS_SERVERLESS_ENV_VERSION=3
DATABRICKS_WORKSPACE_DIR=/Users/<user>/neo4j-mcp-demo
DATABRICKS_VOLUME_PATH=

# SQL execution for local setup/provision_connection.py.
# If DATABRICKS_WAREHOUSE_ID is empty, provision_connection.py falls back to
# DATABRICKS_CLUSTER_ID and Databricks command execution.
DATABRICKS_WAREHOUSE_ID=<your-sql-warehouse-id>

# AgentCore credential source. The operator manually copies this file into
# this directory before setup. Do not commit it.
AGENTCORE_CREDENTIALS_PATH=.mcp-credentials.json

# Databricks resources created or used by the demo.
MCP_SECRET_SCOPE=mcp-neo4j-secrets
UC_CONNECTION_NAME=neo4j_agentcore_mcp
CATALOG=mcp_demo_catalog
SCHEMA=agents
UC_MODEL_NAME=neo4j_mcp_agent

# Agent serving configuration.
# Confirm the endpoint is available in your Databricks region.
LLM_ENDPOINT_NAME=databricks-claude-sonnet-4-6
MODEL_SERVING_ENDPOINT_NAME=neo4j-mcp-agent
SMOKE_TEST_PROMPT=What is the schema of the Neo4j database? Show node labels and relationship types.
