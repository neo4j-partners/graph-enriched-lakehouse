# Databricks CLI settings used by scripts/deploy_from_env.py.
# Configure the profile with: databricks configure --profile <name>
DATABRICKS_PROFILE=
DATABRICKS_BUNDLE_TARGET=dev
DATABRICKS_APP_RESOURCE_KEY=agentic-commerce-app
DATABRICKS_APP_NAME=agentic-commerce
DATABRICKS_DEPLOY_STRICT_VALIDATE=false

# Runtime settings staged into app.yml during deploy for Databricks Apps.
AGENTIC_COMMERCE_RETAIL_AGENT_ENDPOINT_NAME=agents_retail_assistant-retail-retail_agent_v3
AGENTIC_COMMERCE_RETAIL_AGENT_TIMEOUT_SECONDS=120
AGENTIC_COMMERCE_DEMO_DATA_MODE=live
AGENTIC_COMMERCE_DEMO_ALLOW_SAMPLE_FALLBACK=false
AGENTIC_COMMERCE_DEMO_INCLUDE_RAW_ENDPOINT_METADATA=false
